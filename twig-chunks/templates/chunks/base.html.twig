<template data-chunk-marker></template>
{% if fallback is defined and fallback %}
	{{ fallback|raw }}
{% endif %}
{% do assets.addJs('plugin://twig-chunks/js/twig-chunks.js', 1) %}
 <script>(function(script) {
    document.addEventListener('twig-chunks:ready', function() {
        initTwigChunk('{{ chunk|e('js') }}', {{ params|default({})|json_encode|raw }}, script);
    }, { once: true });
})(document.currentScript);</script>
